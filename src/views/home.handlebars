<h1>Lista de Productos</h1>

{{#if products.length}}
  <ul>
    {{#each products}}
      <li>
        <strong>{{this.title}}</strong> — ${{this.price}} | Stock: {{this.stock}} | Categoría: {{this.category}}
      </li>
    {{/each}}
  </ul>
{{else}}
  <p>No hay productos cargados todavía.</p>
{{/if}}

<br />
<a href="/realtimeproducts">→ Ver productos en tiempo real</a>
