<h1>{{product.title}}</h1>
<p><strong>Descripción:</strong> {{product.description}}</p>
<p><strong>Precio:</strong> ${{product.price}}</p>
<p><strong>Categoría:</strong> {{product.category}}</p>
<p><strong>Stock:</strong> {{product.stock}}</p>
<p><strong>Código:</strong> {{product.code}}</p>
<p><strong>Disponible:</strong> {{#if product.status}}Sí{{else}}No{{/if}}</p>
<br/>
<label for="cart-id"><strong>ID del carrito:</strong></label>
<input type="text" id="cart-id" placeholder="Ingresá el ID del carrito" style="width: 300px;" />
<button id="add-to-cart-btn">Agregar al carrito</button>
<p id="cart-msg" style="color: green;"></p>
<br/>
<a href="/">← Volver</a>
<script>
  document.getElementById("add-to-cart-btn").addEventListener("click", async () => {
    const cartId = document.getElementById("cart-id").value.trim();
    if (!cartId) return alert("Ingresá un ID de carrito válido");
    const res = await fetch(`/api/carts/${cartId}/product/{{product._id}}`, { method: "POST" });
    if (res.ok) {
      document.getElementById("cart-msg").textContent = "Producto agregado al carrito!";
    } else {
      document.getElementById("cart-msg").textContent = "Error al agregar el producto.";
      document.getElementById("cart-msg").style.color = "red";
    }
  });
</script>